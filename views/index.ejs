<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tweeter</title>
    <link rel="stylesheet" href=" /style.css">
  </head>
  <body>
    <h2 class="heading">MY PERSONAL TWEETER</h2>

    <% for(post of posts) {%>
        <div>
            <h2 class="user">@<%= post.username %></h2>
            <h2 class="content"><%= post.content %></h2>
        </div>
    <% } %>
  </body>
</html>
